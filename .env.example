# Copy to .env and fill in values (never commit .env)

# Required — same token used by the Next.js app
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# Optional — shared secret; set the same value in the Next.js MANIM_API_KEY env var.
# Leave empty to disable auth (not recommended for production).
RENDER_API_KEY=

# Port (Railway sets this automatically; default: 8000)
PORT=8000
